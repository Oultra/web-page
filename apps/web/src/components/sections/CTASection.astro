---
import { FINAL_CTA } from '@/data/home';
---

<section class="py-24">
  <div class="container">
    <div
      class="relative overflow-hidden text-center bg-bg-2 border border-border rounded-2xl py-16 px-8"
      data-reveal
    >
      <!-- Glow -->
      <div
        class="absolute inset-0 pointer-events-none"
        aria-hidden="true"
        style="background: radial-gradient(ellipse 60% 80% at 50% 0%, rgba(37,99,235,0.15) 0%, transparent 60%);"
      />

      <div class="relative max-w-xl mx-auto">
        <span class="chip chip-blue mb-5 inline-flex">{FINAL_CTA.eyebrow}</span>
        <h2 class="text-3xl md:text-4xl font-bold text-text-1 tracking-tight leading-tight mb-4">
          {FINAL_CTA.headline}
        </h2>
        <p class="text-text-2 text-lg mb-8">{FINAL_CTA.body}</p>

        <a
          href={FINAL_CTA.cta.href}
          class="inline-flex items-center gap-2 px-7 py-3.5 text-sm font-semibold text-white bg-accent-1 hover:bg-blue-500 rounded-md transition-all duration-fast shadow-[0_0_28px_rgba(37,99,235,0.4)] hover:shadow-[0_0_40px_rgba(37,99,235,0.55)] hover:-translate-y-px"
        >
          {FINAL_CTA.cta.label}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>

        <p class="mt-5 text-xs text-text-3">
          {FINAL_CTA.note}
        </p>
      </div>
    </div>
  </div>
</section>
