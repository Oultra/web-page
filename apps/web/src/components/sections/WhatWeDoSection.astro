---
import { WHAT_WE_DO } from '@/data/home';
import SectionShell from '@/components/ui/SectionShell.astro';

const ICONS: Record<string, string> = {
  grid: `<path d="M3 3h4v4H3V3zm6 0h4v4H9V3zm0 6h4v4H9V9zm-6 0h4v4H3V9z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>`,
  code: `<path d="M4 8l-2-2 2-2M8 4l2 2-2 2M6 4l-1 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
  bolt: `<path d="M9 2L4 8h4l-1 4 5-6H8l1-4z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>`,
};
---

<SectionShell
  eyebrow="What we do"
  heading="Software built to last. AI that actually ships."
  subheading="We work across the full stack — from custom applications to AI integration — and we also build and maintain our own products."
>
  <div class="grid md:grid-cols-3 gap-5">
    {WHAT_WE_DO.map((item, i) => (
      <div
        class="group bg-bg-2 border border-border rounded-xl p-6 hover:border-border-strong transition-colors duration-mid"
        data-reveal
        data-delay={String(i + 1) as "1" | "2" | "3"}
      >
        <div class="w-9 h-9 rounded-md bg-accent-1/10 border border-accent-1/20 flex items-center justify-center mb-4">
          <svg width="16" height="16" viewBox="0 0 12 12" fill="none" class="text-accent-2" set:html={ICONS[item.icon]} aria-hidden="true" />
        </div>
        <h3 class="text-base font-semibold text-text-1 mb-2">{item.title}</h3>
        <p class="text-sm text-text-2 leading-relaxed mb-3">{item.body}</p>
        {'link' in item && item.link && (
          <a
            href={item.link.href}
            class="inline-flex items-center gap-1.5 text-xs font-medium text-accent-1 hover:text-accent-2 transition-colors duration-fast"
          >
            {item.link.label}
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M2 6h8M6 2l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        )}
      </div>
    ))}
  </div>
</SectionShell>
