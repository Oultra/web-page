---
import MatrixRain from '@/components/motion/MatrixRain';
import { useTranslations } from '@/lib/i18n';
const t = useTranslations(Astro.currentLocale);
---

<section class="py-24 relative overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <!-- Matrix rain — activates when section enters viewport -->
    <MatrixRain client:visible />
    <div class="absolute inset-0 bg-grid opacity-15" />
    <div
      class="absolute inset-0"
      style="background: radial-gradient(ellipse 70% 60% at 100% 50%, rgba(99,102,241,0.08) 0%, transparent 60%);"
    />
  </div>

  <div class="container relative">
    <div class="max-w-3xl" data-reveal>
      <span class="chip chip-cyan mb-5 inline-flex">{t.whyItMatters.eyebrow}</span>
      <h2 class="text-3xl md:text-4xl font-bold text-text-1 tracking-tight leading-tight mb-8">
        {t.whyItMatters.headline}
      </h2>

      <div class="space-y-5">
        {t.whyItMatters.paragraphs.map((p, i) => (
          <p
            class="text-text-2 text-lg leading-relaxed"
            data-reveal
            data-delay={String(i + 1) as "1" | "2" | "3"}
          >
            {p}
          </p>
        ))}
      </div>
    </div>
  </div>
</section>
