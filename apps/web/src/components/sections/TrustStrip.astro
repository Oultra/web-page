---
import { TRUST_STATS } from '@/data/home';
---

<section class="border-y border-border bg-bg-1/50">
  <div class="container py-8">
    <ul
      class="flex flex-wrap items-center justify-center md:justify-around gap-8"
      role="list"
      aria-label="Product highlights"
    >
      {TRUST_STATS.map(stat => (
        <li class="flex flex-col items-center gap-1 text-center min-w-[80px]">
          <span class="text-2xl font-bold text-text-1 tracking-tight">{stat.value}</span>
          <span class="text-xs text-text-3 uppercase tracking-wider">{stat.label}</span>
        </li>
      ))}
    </ul>
  </div>
</section>
