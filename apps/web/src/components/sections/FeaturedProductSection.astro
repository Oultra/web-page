---
import { PRODUCTS } from '@/data/site';
---

<section class="py-24">
  <div class="container">
    <div
      class="relative overflow-hidden bg-bg-2 border border-border rounded-2xl"
      data-reveal
    >
      <!-- Top glow -->
      <div
        class="absolute inset-0 pointer-events-none"
        aria-hidden="true"
        style="background: radial-gradient(ellipse 60% 50% at 0% 50%, rgba(37,99,235,0.1) 0%, transparent 70%);"
      />

      <div class="relative grid lg:grid-cols-2 gap-0">
        <!-- Content -->
        <div class="p-8 md:p-12 flex flex-col justify-center">
          <div class="chip chip-cyan mb-5 inline-flex w-fit">Our tools</div>

          <h2 class="text-3xl md:text-4xl font-bold text-text-1 tracking-tight leading-tight mb-4">
            {PRODUCTS.aiReadiness.name}
          </h2>

          <p class="text-text-2 text-lg leading-relaxed mb-8 max-w-md">
            {PRODUCTS.aiReadiness.description}
          </p>

          <ul class="space-y-3 mb-8" aria-label="What the audit covers">
            {[
              'Metadata & title tag quality',
              'JSON-LD structured data coverage',
              'Content readability and density',
              'Performance signals',
              'Accessibility semantics',
              'Crawlability and sitemap health',
            ].map(item => (
              <li class="flex items-start gap-2.5 text-sm text-text-2">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="mt-0.5 shrink-0 text-success" aria-hidden="true">
                  <path d="M3 8l3.5 3.5L13 5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>

          <div class="flex flex-wrap gap-3">
            <a
              href={PRODUCTS.aiReadiness.url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-semibold text-white bg-accent-1 hover:bg-blue-500 rounded-md transition-colors duration-fast"
            >
              Start free audit
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a
              href={PRODUCTS.aiReadiness.slug}
              class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium text-text-2 bg-bg-3 border border-border hover:text-text-1 rounded-md transition-colors duration-fast"
            >
              Learn more
            </a>
          </div>
        </div>

        <!-- Preview panel -->
        <div class="border-t lg:border-t-0 lg:border-l border-border bg-bg-1/50 p-8 md:p-10 flex flex-col gap-5">
          <p class="text-xs font-mono text-text-3 uppercase tracking-wider">Example audit result</p>

          <!-- Score summary -->
          <div class="flex items-center gap-4">
            <div class="flex items-center justify-center w-16 h-16 rounded-full border-4 border-accent-1/50 bg-bg-0">
              <span class="text-xl font-bold text-text-1 tabular-nums">74</span>
            </div>
            <div>
              <p class="text-sm font-semibold text-text-1">Overall Score</p>
              <p class="text-xs text-warning">Needs improvement</p>
            </div>
          </div>

          <!-- Category bars -->
          <div class="space-y-3">
            {[
              { name: 'Metadata', score: 85, color: 'bg-gradient-to-r from-success to-accent-2' },
              { name: 'Structured Data', score: 60, color: 'bg-gradient-to-r from-accent-1 to-accent-2' },
              { name: 'Content Quality', score: 78, color: 'bg-gradient-to-r from-accent-1 to-accent-2' },
              { name: 'Performance', score: 71, color: 'bg-gradient-to-r from-accent-1 to-accent-2' },
              { name: 'Accessibility', score: 82, color: 'bg-gradient-to-r from-success to-accent-2' },
              { name: 'Crawlability', score: 65, color: 'bg-gradient-to-r from-warning to-accent-1' },
            ].map(cat => (
              <div>
                <div class="flex justify-between mb-1">
                  <span class="text-xs text-text-3">{cat.name}</span>
                  <span class="text-xs font-mono text-text-2">{cat.score}</span>
                </div>
                <div class="score-bar-track">
                  <div class={`score-bar-fill ${cat.color}`} style={`width: ${cat.score}%`} />
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
