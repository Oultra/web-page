---
import HeroAsciiBackground from '@/components/motion/HeroAsciiBackground';
import HeroAIPanel from '@/components/motion/HeroAIPanel';
import TextScramble from '@/components/motion/TextScramble';
import { useTranslations } from '@/lib/i18n';

const t = useTranslations(Astro.currentLocale);
const prefix = Astro.currentLocale === 'es' ? '/es' : '';
---

<section class="relative min-h-[100svh] flex items-center pt-24 pb-16 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <!-- Full-bleed ASCII background with logo animation -->
    <HeroAsciiBackground client:load />

    <!-- Radial glow — breathes slowly -->
    <div
      class="absolute inset-0 glow-breathe"
      style="background: radial-gradient(ellipse 80% 60% at 60% 40%, rgba(37,99,235,0.12) 0%, rgba(99,102,241,0.08) 40%, transparent 70%);"
    />
    <!-- Bottom fade -->
    <div class="absolute bottom-0 inset-x-0 h-32 bg-gradient-to-t from-bg-0 to-transparent" />
  </div>

  <div class="container relative">
    <div class="grid lg:grid-cols-2 gap-12 xl:gap-20 items-center">

      <!-- Left: Text -->
      <div class="max-w-xl">
        <!-- Eyebrow -->
        <div class="mb-5" data-reveal>
          <span class="chip chip-blue">
            <svg width="8" height="8" viewBox="0 0 8 8" fill="none" aria-hidden="true" class="rounded-full bg-accent-2 w-1.5 h-1.5" />
            {t.hero.eyebrow}
          </span>
        </div>

        <!-- Headline — scrambles in on load -->
        <div
          class="text-3xl sm:text-4xl md:text-5xl xl:text-6xl font-bold text-text-1 tracking-tight leading-[1.05] mb-6"
          data-reveal
          data-delay="1"
        >
          <TextScramble
            client:load
            text={t.hero.headline}
            tag="h1"
            className="text-3xl sm:text-4xl md:text-5xl xl:text-6xl font-bold text-text-1 tracking-tight leading-[1.05] m-0"
            startDelay={400}
          />
        </div>

        <!-- Subheadline -->
        <p
          class="text-lg text-text-2 leading-relaxed mb-8 max-w-lg"
          data-reveal
          data-delay="2"
        >
          {t.hero.subheadline}
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-3 mb-6" data-reveal data-delay="3">
          <a
            href={`${prefix}/contact`}
            class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-white bg-accent-1 hover:bg-blue-500 rounded-md transition-all duration-fast shadow-[0_0_24px_rgba(37,99,235,0.35)] hover:shadow-[0_0_32px_rgba(37,99,235,0.5)] hover:-translate-y-px"
          >
            {t.hero.ctaPrimary}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a
            href={`${prefix}/products/ai-readiness`}
            class="inline-flex items-center gap-2 px-6 py-3 text-sm font-medium text-text-2 bg-bg-2 border border-border hover:border-border-strong hover:text-text-1 rounded-md transition-colors duration-fast"
          >
            {t.hero.ctaSecondary}
          </a>
        </div>

        <!-- Credibility hint -->
        <p class="text-xs text-text-3" data-reveal data-delay="4">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="inline mr-1.5 text-success" aria-hidden="true">
            <circle cx="6" cy="6" r="5" fill="currentColor" opacity="0.2"/>
            <path d="M3.5 6l1.5 1.5L8.5 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          {t.hero.credibility}
        </p>
      </div>

      <!-- Right: AI panel (cycles pipeline → stream → neural) -->
      <div class="relative hidden lg:flex justify-end items-center" data-reveal data-delay="2">
        <HeroAIPanel client:load />
      </div>

    </div>
  </div>
</section>
