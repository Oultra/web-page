---
import { HOW_IT_WORKS } from '@/data/home';
import SectionShell from '@/components/ui/SectionShell.astro';
---

<SectionShell
  eyebrow="How we work"
  heading="From conversation to shipped software."
  id="how-it-works"
>
  <div class="grid md:grid-cols-3 gap-6 relative">
    <!-- Connector line (desktop only) -->
    <div class="hidden md:block absolute top-8 left-[16.66%] right-[16.66%] h-px bg-gradient-to-r from-transparent via-border to-transparent" aria-hidden="true" />

    {HOW_IT_WORKS.map((step, i) => (
      <div class="relative flex flex-col items-start gap-4" data-reveal data-delay={String(i + 1) as "1" | "2" | "3"}>
        <!-- Step number -->
        <div class="relative z-10 flex items-center justify-center w-14 h-14 rounded-xl bg-bg-2 border border-border-strong">
          <span class="font-mono text-xl font-bold text-accent-1">{step.step}</span>
        </div>

        <div>
          <h3 class="text-base font-semibold text-text-1 mb-2">{step.title}</h3>
          <p class="text-sm text-text-2 leading-relaxed">{step.body}</p>
        </div>
      </div>
    ))}
  </div>
</SectionShell>
