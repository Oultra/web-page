---
interface Props {
  eyebrow?: string;
  heading?: string;
  subheading?: string;
  align?: 'left' | 'center';
  class?: string;
  id?: string;
}

const {
  eyebrow,
  heading,
  subheading,
  align = 'left',
  class: className = '',
  id,
} = Astro.props;

const textAlign = align === 'center' ? 'text-center mx-auto' : '';
const maxW = align === 'center' ? 'max-w-2xl mx-auto' : 'max-w-2xl';
---

<section class={`py-24 ${className}`} {id}>
  <div class="container">
    {(eyebrow || heading || subheading) && (
      <div class={`mb-14 ${textAlign}`} data-reveal>
        {eyebrow && (
          <p class="chip chip-blue mb-4 inline-flex">
            {eyebrow}
          </p>
        )}
        {heading && (
          <h2 class={`text-3xl md:text-4xl font-bold text-text-1 tracking-tight leading-tight mb-4 ${maxW}`}>
            {heading}
          </h2>
        )}
        {subheading && (
          <p class={`text-text-2 text-lg leading-relaxed ${maxW}`}>
            {subheading}
          </p>
        )}
      </div>
    )}
    <slot />
  </div>
</section>
