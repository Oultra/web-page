---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  external?: boolean;
  type?: 'button' | 'submit';
}

const {
  href,
  variant = 'primary',
  size = 'md',
  class: className = '',
  external = false,
  type = 'button',
} = Astro.props;

const variants = {
  primary: 'bg-accent-1 text-white hover:bg-blue-500 shadow-[0_0_20px_rgba(37,99,235,0.3)] hover:shadow-[0_0_28px_rgba(37,99,235,0.45)]',
  secondary: 'bg-bg-3 text-text-1 border border-border-strong hover:border-accent-1/40 hover:text-text-1',
  ghost: 'text-text-2 hover:text-text-1 hover:bg-bg-2',
};

const sizes = {
  sm: 'px-3.5 py-1.5 text-sm gap-1.5',
  md: 'px-5 py-2.5 text-sm gap-2',
  lg: 'px-6 py-3 text-base gap-2',
};

const classes = `inline-flex items-center justify-center font-medium rounded-md transition-all duration-fast ${variants[variant]} ${sizes[size]} ${className}`;
---

{href ? (
  <a
    href={href}
    class={classes}
    {...external && { target: '_blank', rel: 'noopener noreferrer' }}
  >
    <slot />
  </a>
) : (
  <button type={type} class={classes}>
    <slot />
  </button>
)}
