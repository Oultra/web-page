---
import { useTranslations } from '@/lib/i18n';

const t = useTranslations(Astro.currentLocale);
const prefix = Astro.currentLocale === 'es' ? '/es' : '';
---

<footer class="border-t border-border mt-32">
  <div class="container py-16">
    <div class="grid grid-cols-1 md:grid-cols-5 gap-8 md:gap-10">
      <!-- Brand column -->
      <div class="md:col-span-1">
        <a href={`${prefix}/`} class="flex items-center gap-2.5 font-semibold text-text-1 tracking-tight mb-4" aria-label="Oultra">
          <svg width="24" height="24" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect width="32" height="32" rx="8" fill="#080a0f"/>
            <rect x="6" y="6" width="8" height="8" rx="2" fill="#2563eb"/>
            <rect x="18" y="6" width="8" height="8" rx="2" fill="#06b6d4" opacity="0.7"/>
            <rect x="6" y="18" width="8" height="8" rx="2" fill="#6366f1" opacity="0.7"/>
            <rect x="18" y="18" width="8" height="8" rx="2" fill="#2563eb" opacity="0.4"/>
          </svg>
          <span class="text-[15px]">Oultra</span>
        </a>
        <p class="text-sm text-text-3 leading-relaxed max-w-[200px]">
          {t.footer.tagline}
        </p>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-xs font-semibold text-text-3 uppercase tracking-wider mb-4">{t.footer.services}</h3>
        <ul class="space-y-2.5" role="list">
          {t.footer.servicesLinks.map(link => (
            <li>
              <a href={`${prefix}${link.href}`} class="text-sm text-text-2 hover:text-text-1 transition-colors duration-fast">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Products -->
      <div>
        <h3 class="text-xs font-semibold text-text-3 uppercase tracking-wider mb-4">{t.footer.products}</h3>
        <ul class="space-y-2.5" role="list">
          {t.footer.productsLinks.map(link => (
            <li>
              <a href={`${prefix}${link.href}`} class="text-sm text-text-2 hover:text-text-1 transition-colors duration-fast">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-xs font-semibold text-text-3 uppercase tracking-wider mb-4">{t.footer.company}</h3>
        <ul class="space-y-2.5" role="list">
          {t.footer.companyLinks.map(link => (
            <li>
              <a href={`${prefix}${link.href}`} class="text-sm text-text-2 hover:text-text-1 transition-colors duration-fast">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="text-xs font-semibold text-text-3 uppercase tracking-wider mb-4">{t.footer.legal}</h3>
        <ul class="space-y-2.5" role="list">
          {t.footer.legalLinks.map(link => (
            <li>
              <a href={`${prefix}${link.href}`} class="text-sm text-text-2 hover:text-text-1 transition-colors duration-fast">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="border-t border-border mt-12 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-text-3">
        &copy; {new Date().getFullYear()} Oultra. {t.footer.rights}
      </p>
      <a href="mailto:contact@oultra.dev" class="text-xs text-text-3 hover:text-text-2 transition-colors duration-fast">
        contact@oultra.dev
      </a>
    </div>
  </div>
</footer>
