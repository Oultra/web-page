---
import { SITE } from '@/data/site';
import MobileMenu from '@/components/motion/MobileMenu';
import LangSwitcher from '@/components/motion/LangSwitcher';
import { useTranslations } from '@/lib/i18n';

const t = useTranslations(Astro.currentLocale);
const locale = Astro.currentLocale ?? 'en';
const prefix = locale === 'es' ? '/es' : '';
---

<header class="site-header fixed top-0 left-0 right-0 z-50">
  <div class="container">
    <nav class="flex items-center justify-between h-16" aria-label="Main navigation">
      <!-- Logo -->
      <a href={`${prefix}/`} class="flex items-center gap-2.5 font-semibold text-text-1 tracking-tight" aria-label={SITE.name}>
        <svg width="28" height="28" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect width="32" height="32" rx="8" fill="#080a0f"/>
          <rect x="6" y="6" width="8" height="8" rx="2" fill="#2563eb"/>
          <rect x="18" y="6" width="8" height="8" rx="2" fill="#06b6d4" opacity="0.7"/>
          <rect x="6" y="18" width="8" height="8" rx="2" fill="#6366f1" opacity="0.7"/>
          <rect x="18" y="18" width="8" height="8" rx="2" fill="#2563eb" opacity="0.4"/>
        </svg>
        <span class="text-[15px]">Oultra</span>
      </a>

      <!-- Desktop nav -->
      <ul class="hidden md:flex items-center gap-1" role="list">
        <li>
          <a href={`${prefix}/`} class="nav-link px-3 py-1.5 text-sm text-text-2 hover:text-text-1 rounded-md transition-colors duration-fast">
            {t.nav.home}
          </a>
        </li>

        <!-- Work dropdown -->
        <li class="relative group">
          <button
            class="nav-link flex items-center gap-1 px-3 py-1.5 text-sm text-text-2 hover:text-text-1 rounded-md transition-colors duration-fast"
            aria-haspopup="true"
            aria-expanded="false"
          >
            {t.nav.work}
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true" class="transition-transform duration-fast group-hover:rotate-180">
              <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <div class="absolute top-full left-0 mt-1.5 w-72 md:w-80 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-mid origin-top-left">
            <div class="bg-bg-2 border border-border rounded-lg shadow-card overflow-hidden p-1">
              {t.nav.workItems.map(item => (
                <a
                  href={`${prefix}${item.href}`}
                  class="flex items-start gap-3 px-3 py-2.5 rounded-md hover:bg-bg-3 transition-colors duration-fast"
                >
                  <div class="flex-1 min-w-0">
                    <span class="text-sm font-medium text-text-1">{item.label}</span>
                    <span class="block text-xs text-text-3 mt-0.5">{item.description}</span>
                  </div>
                  {item.badge && (
                    <span class={`chip text-[10px] py-0.5 px-1.5 shrink-0 mt-0.5 ${item.badge === 'Product' || item.badge === 'Producto' ? 'chip-blue' : 'chip-cyan'}`}>
                      {item.badge}
                    </span>
                  )}
                </a>
              ))}
            </div>
          </div>
        </li>

        <li>
          <a href={`${prefix}/company`} class="nav-link px-3 py-1.5 text-sm text-text-2 hover:text-text-1 rounded-md transition-colors duration-fast">
            {t.nav.company}
          </a>
        </li>
        <li>
          <a href={`${prefix}/contact`} class="nav-link px-3 py-1.5 text-sm text-text-2 hover:text-text-1 rounded-md transition-colors duration-fast">
            {t.nav.contact}
          </a>
        </li>
      </ul>

      <!-- Desktop CTA + LangSwitcher -->
      <div class="hidden md:flex items-center gap-3">
        <LangSwitcher client:load />
        <a
          href={`${prefix}/contact`}
          class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-white bg-accent-1 hover:bg-blue-500 rounded-md transition-colors duration-fast"
        >
          {t.nav.startProject}
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <!-- Mobile menu trigger -->
      <MobileMenu
        client:load
        navItems={t.nav.workItems.map(item => ({ ...item, href: `${prefix}${item.href}` }))}
        homeLabel={t.nav.home}
        companyLabel={t.nav.company}
        contactLabel={t.nav.contact}
        startProjectLabel={t.nav.startProject}
        prefix={prefix}
      />
    </nav>
  </div>
</header>

<style>
  .nav-link {
    position: relative;
  }
</style>
