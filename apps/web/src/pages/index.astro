---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/sections/Hero.astro';
import TrustStrip from '@/components/sections/TrustStrip.astro';
import WhatWeDoSection from '@/components/sections/WhatWeDoSection.astro';
import FeaturedProductSection from '@/components/sections/FeaturedProductSection.astro';
import HowItWorksSection from '@/components/sections/HowItWorksSection.astro';
import ExampleResultsSection from '@/components/sections/ExampleResultsSection.astro';
import WhyItMattersSection from '@/components/sections/WhyItMattersSection.astro';
import FutureProductsRail from '@/components/sections/FutureProductsRail.astro';
import CTASection from '@/components/sections/CTASection.astro';
---

<BaseLayout
  title="Oultra"
  description="Oultra builds practical AI software. Start with AI Readiness Audit — measure how visible, structured, and machine-readable your website really is."
