>
  <Hero />
  <TrustStrip />
  <WhatWeDoSection />
  <FeaturedProductSection />
  <HowItWorksSection />
  <ExampleResultsSection />
  <WhyItMattersSection />
  <FutureProductsRail />
  <CTASection />
</BaseLayout>
