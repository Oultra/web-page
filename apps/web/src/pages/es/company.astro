---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionShell from '@/components/ui/SectionShell.astro';
import { useTranslations } from '@/lib/i18n';
const t = useTranslations(Astro.currentLocale);
---

<BaseLayout
  title={t.pages.company.title}
  description={t.pages.company.description}
  canonical="/es/company"
>
  <section class="pt-32 pb-20 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute inset-0 bg-grid opacity-30" />
      <div class="absolute inset-0" style="background: radial-gradient(ellipse 60% 50% at 20% 30%, rgba(99,102,241,0.1) 0%, transparent 60%);" />
    </div>
    <div class="container relative max-w-3xl">
      <span class="chip chip-blue mb-5 inline-flex">{t.company.eyebrow}</span>
      <h1 class="text-4xl md:text-5xl font-bold text-text-1 tracking-tight leading-[1.05] mb-6">{t.company.headline}</h1>
      <p class="text-text-2 text-xl leading-relaxed">{t.company.description}</p>
    </div>
  </section>

  <SectionShell>
    <div class="grid md:grid-cols-2 gap-16 items-start">
      <div data-reveal>
        <h2 class="text-2xl font-bold text-text-1 tracking-tight mb-5">{t.company.whatWeDo.heading}</h2>
        {t.company.whatWeDo.paragraphs.map(p => (
          <p class="text-text-2 leading-relaxed mb-5">{p}</p>
        ))}
      </div>
      <div data-reveal data-delay="1">
        <h2 class="text-2xl font-bold text-text-1 tracking-tight mb-5">{t.company.howWeWork.heading}</h2>
        <ul class="space-y-5" role="list">
          {t.company.howWeWork.principles.map(item => (
            <li class="flex gap-4">
              <div class="w-1 min-h-[2rem] bg-gradient-to-b from-accent-1 to-accent-3 rounded-full shrink-0 mt-1" aria-hidden="true" />
              <div>
                <h3 class="text-sm font-semibold text-text-1 mb-1">{item.title}</h3>
                <p class="text-sm text-text-2 leading-relaxed">{item.body}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </SectionShell>

  <section class="py-24 bg-bg-1/50 border-y border-border" id="services">
    <div class="container">
      <div class="mb-12" data-reveal>
        <span class="chip chip-cyan mb-4 inline-flex">{t.company.services.eyebrow}</span>
        <h2 class="text-3xl font-bold text-text-1 tracking-tight mb-4">{t.company.services.heading}</h2>
        <p class="text-text-2 text-lg max-w-xl">{t.company.services.subheading}</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {t.services.map((service, i) => (
          <div
            class="bg-bg-2 border border-border rounded-xl p-6 hover:border-border-strong transition-colors duration-mid"
            data-reveal
            data-delay={String(i + 1) as "1" | "2" | "3"}
          >
            <h3 class="text-base font-semibold text-text-1 mb-2">{service.name}</h3>
            <p class="text-sm text-text-2 leading-relaxed mb-4">{service.description}</p>
            <a href="/es/contact" class="inline-flex items-center gap-1.5 text-sm font-medium text-accent-1 hover:text-accent-2 transition-colors duration-fast">
              {t.company.services.getInTouch}
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M2 6h8M6 2l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <SectionShell>
    <div class="mb-12" data-reveal>
      <span class="chip chip-blue mb-4 inline-flex">{t.company.ourProducts.eyebrow}</span>
      <h2 class="text-3xl font-bold text-text-1 tracking-tight mb-4">{t.company.ourProducts.heading}</h2>
      <p class="text-text-2 text-lg max-w-xl">{t.company.ourProducts.subheading}</p>
    </div>
    <div class="grid md:grid-cols-2 gap-5" data-reveal data-delay="1">
      <div class="bg-bg-2 border border-accent-1/30 rounded-xl p-6">
        <div class="flex items-center justify-between mb-3">
          <span class="text-base font-semibold text-text-1">{t.company.liveProduct.name}</span>
          <span class="chip chip-success">{t.company.liveProduct.badge}</span>
        </div>
        <p class="text-sm text-text-2 leading-relaxed mb-4">{t.company.liveProduct.description}</p>
        <div class="flex gap-3">
          <a href="https://aireadiness.oultra.dev" target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-accent-1 hover:text-accent-2 transition-colors duration-fast">
            {t.company.liveProduct.tryIt}
          </a>
          <a href="/es/products/ai-readiness" class="text-sm font-medium text-text-3 hover:text-text-2 transition-colors duration-fast">
            {t.company.liveProduct.learnMore}
          </a>
        </div>
      </div>
      <div class="bg-bg-2/50 border border-border rounded-xl p-6 opacity-70">
        <div class="flex items-center justify-between mb-3">
          <span class="text-base font-semibold text-text-2">{t.company.comingSoon.heading}</span>
          <span class="chip chip-cyan">{t.company.comingSoon.badge}</span>
        </div>
        <p class="text-sm text-text-3 leading-relaxed">{t.company.comingSoon.description}</p>
      </div>
    </div>
  </SectionShell>

  <section class="py-24">
    <div class="container text-center max-w-xl">
      <div data-reveal>
        <h2 class="text-2xl font-bold text-text-1 tracking-tight mb-4">{t.company.contactCta.heading}</h2>
        <p class="text-text-2 mb-8">{t.company.contactCta.subheading}</p>
        <a href="/es/contact" class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-white bg-accent-1 hover:bg-blue-500 rounded-md transition-colors duration-fast">
          {t.company.contactCta.ctaLabel}
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
