---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionShell from '@/components/ui/SectionShell.astro';
import ProductCard from '@/components/ui/ProductCard.astro';
import CTASection from '@/components/sections/CTASection.astro';
import { PRODUCTS } from '@/data/site';
import { useTranslations } from '@/lib/i18n';
const t = useTranslations(Astro.currentLocale);
---

<BaseLayout
  title={t.pages.products.title}
  description={t.pages.products.description}
  canonical="/es/products"
>
  <section class="pt-32 pb-16 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute inset-0 bg-grid opacity-30" />
      <div class="absolute inset-0" style="background: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(99,102,241,0.1) 0%, transparent 60%);" />
    </div>
    <div class="container relative text-center">
      <span class="chip chip-blue mb-5 inline-flex">{t.productsPage.eyebrow}</span>
      <h1 class="text-4xl md:text-5xl font-bold text-text-1 tracking-tight leading-tight mb-5 max-w-2xl mx-auto">{t.productsPage.headline}</h1>
      <p class="text-text-2 text-lg max-w-xl mx-auto">{t.productsPage.subheading}</p>
    </div>
  </section>

  <SectionShell>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <div data-reveal>
        <ProductCard
          name={t.products.aiReadiness.name}
          description={t.products.aiReadiness.tagline}
          href={`/es${PRODUCTS.aiReadiness.slug}`}
          badge={t.productsPage.availableNow}
          status="live"
        />
      </div>
      <div data-reveal data-delay="1">
        <ProductCard
          name={t.productsPage.comingSoon1.name}
          description={t.productsPage.comingSoon1.description}
          href="#"
          status="coming-soon"
        />
      </div>
      <div data-reveal data-delay="2">
        <ProductCard
          name={t.productsPage.comingSoon2.name}
          description={t.productsPage.comingSoon2.description}
          href="#"
          status="coming-soon"
        />
      </div>
    </div>
  </SectionShell>

  <CTASection />
</BaseLayout>
